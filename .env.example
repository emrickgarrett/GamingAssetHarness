# OpenRouter - LLM provider for agent reasoning
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Gemini - NanoBanana 2D sprite/texture generation
GEMINI_API_KEY=your_gemini_api_key_here

# Meshy - 3D model generation
MESHY_API_KEY=your_meshy_api_key_here

# Suno - Music generation
SUNO_API_KEY=your_suno_api_key_here

# ElevenLabs - Sound effect generation
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: workspace storage directory (defaults to ./workspaces)
# WORKSPACES_ROOT=/path/to/workspaces
